---
import WindowsIcon from './icons/WindowsIcon.astro';
import MacOsIcon from './icons/MacOsIcon.astro';
import LinuxIcon from './icons/LinuxIcon.astro';
import AndroidIcon from './icons/AndroidIcon.astro';

interface Props {
  title: string;
  description: string;
  repoUrl: string;
  webUrl?: string;
  logoUrl?: string;
  osSupport?: ('windows' | 'macos' | 'linux' | 'android')[];
}

const { title, description, repoUrl, webUrl, logoUrl, osSupport = [] } = Astro.props;
const releasesUrl = `${repoUrl}/releases/latest`;
---

<div class="bg-dark-800 p-6 rounded-xl border border-dark-700 hover:border-dark-600 transition-all duration-300 shadow-lg flex flex-col">
  <div class="flex items-center gap-4 mb-4">
    {logoUrl && (
      <img src={logoUrl} alt={`${title} logo`} class="w-12 h-12 object-contain rounded-lg" />
    )}
    <h2 class="text-xl font-bold text-white">{title}</h2>
  </div>
  <p class="text-gray-400 mb-6 text-sm leading-relaxed flex-grow">{description}</p>
  
  <div class="flex items-center justify-between mt-auto">
    <div class="flex gap-2 text-gray-500">
      {osSupport.includes('windows') && <WindowsIcon />}
      {osSupport.includes('macos') && <MacOsIcon />}
      {osSupport.includes('linux') && <LinuxIcon />}
      {osSupport.includes('android') && <AndroidIcon />}
    </div>
    
    <div class="flex gap-4 text-sm font-medium">
      <a href={repoUrl} target="_blank" class="text-gray-300 hover:text-white transition-colors">GitHub</a>
      <a href={releasesUrl} target="_blank" class="text-gray-300 hover:text-white transition-colors">Releases</a>
      {webUrl && (
        <a href={webUrl} target="_blank" class="text-blue-400 hover:text-blue-300 transition-colors">Web</a>
      )}
    </div>
  </div>
</div>
