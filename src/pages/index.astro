---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    title: 'GEP (Gestor d\'Events i Personal)',
    description: 'Sistema integral per a la gestió d\'events, calendari d\'activitats i seguiment de personal, optimitzat per a un control detallat i eficient. Inclou aplicació d\'escriptori (Electron/React) i aplicació mòbil (Expo/React Native).',
    repoUrl: 'https://github.com/Pepelocotango/Gestor-Events_i_Personal',
    webUrl: 'https://gestor-events-i-personal-landingpag.vercel.app/gep-mailer',
    logoUrl: '/logos/gep.png',
    osSupport: ['windows', 'macos', 'linux', 'android'],
  },
  {
    title: 'GEP Mailer Proto',
    description: 'Prototip funcional d\'un servei d\'enviament de correus electrònics integrat amb les necessitats d\'automatització del projecte GEP, fent servir format "Nested Mailto".',
    repoUrl: 'https://github.com/Pepelocotango/gep-mailer-proto',
    webUrl: 'https://gestor-events-i-personal-landingpag.vercel.app/gep-mailer',
    logoUrl: '/logos/gep-mailer.png',
    osSupport: ['windows', 'macos', 'linux'],
  },
  {
    title: 'APP HoresFreelance',
    description: 'Aplicació multiplataforma de registre de jornada per a autònoms per gestionar hores, "bolos", facturació i calendaris. Utilitza una base de dades JSON local compartida.',
    repoUrl: 'https://github.com/Pepelocotango/APP_HoresFreelance',
    logoUrl: '/logos/hores-freelance.svg',
    osSupport: ['windows', 'macos', 'linux', 'android'],
  },
  {
    title: 'QlistGoStyle & AdjustImage',
    description: 'Conjunt d\'scripts en Lua i configuracions d\'estil per a OBS Studio per gestionar llistes de reproducció visuals (Qlist) i automatitzar processos de tractament d\'imatges.',
    repoUrl: 'https://github.com/Pepelocotango/QlistGoStyle_and_AdjustImage_Lua_scripts',
    logoUrl: '/logos/qlist-go-style.png',
    osSupport: ['windows', 'macos', 'linux'],
  },
  {
    title: 'Gt ALL Chords app',
    description: 'Aplicació interactiva dedicada a la identificació i aprenentatge d\'acords de guitarra, incloent diccionari flamenc, cercle de quintes i identificador d\'acords en diapasó.',
    repoUrl: 'https://github.com/Pepelocotango/Gt_ALL_Chords_app',
    logoUrl: '/logos/chords-app.png',
    osSupport: ['windows', 'macos', 'linux'],
  },
  {
    title: 'PC Conf',
    description: 'Repositori de configuracions personals, scripts d\'entorn (dotfiles) i configurador/pressupostador de peces de maquinari de PC amb base de dades local.',
    repoUrl: 'https://github.com/Pepelocotango/pc-conf',
    logoUrl: '/logos/pc-conf.svg',
    osSupport: ['windows', 'macos', 'linux'],
  },
  {
    title: 'Dev Command Runner',
    description: 'Eina d\'escriptori moderna per organitzar, catalogar i llançar còmodament comandes o scripts freqüents de la terminal.',
    repoUrl: 'https://github.com/Pepelocotango/DEV_COMMAND_RUNNER',
    logoUrl: '/logos/dev-runner.png',
    osSupport: ['windows', 'macos', 'linux'],
  },
  {
    title: 'Control Redshift',
    description: 'Utilitat amb interfície gràfica per programar transicions de mode Dia/Nit a Ubuntu MATE, canviant temes GTK i gestionant la lluminositat de la pantalla.',
    repoUrl: 'https://github.com/Pepelocotango/control_redshift_and_temes_UbuntuMate',
    osSupport: ['linux'],
  },
  {
    title: 'Bloc Notes Color (Electron)',
    description: 'Aplicació d\'escriptori construïda amb Electron per organitzar notes ràpides mitjançant una interfície basada en colors.',
    repoUrl: 'https://github.com/Pepelocotango/bloc_de_notes_per_color_dev_compil1',
    logoUrl: '/logos/bloc-notes.png',
    osSupport: ['windows', 'macos', 'linux'],
  },
  {
    title: 'Programa Descans',
    description: 'Aplicació per promoure hàbits saludables recordant fer pauses periòdiques d\'ergonomia laboral (pauses per a la vista i el cos) durant la jornada de treball.',
    repoUrl: 'https://github.com/Pepelocotango/programa_descans',
    osSupport: ['linux'],
  },
];
---

<Layout title="Projectes">
  <main class="container mx-auto px-6 py-16">
    <div class="text-center mb-16">
      <img src="/logo-corporatiu.png" alt="Logo Corporatiu" class="w-32 h-32 object-cover rounded-full mx-auto mb-4 border-4 border-dark-700 shadow-xl" />
      <a href="mailto:pepelocotango@gmail.com" class="text-blue-400 hover:text-blue-300 font-medium block mb-6">pepelocotango@gmail.com</a>
      <h1 class="text-5xl font-extrabold text-white mb-6">Projectes</h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Una col·lecció de eines, aplicacions i configuracions.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </main>
</Layout>
